# ShorTED Lambda AI Orchestrator — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Connection URI from MongoDB Atlas ShorTED cluster
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=shorted

# ── AWS / S3 ─────────────────────────────────────────────────────────────────
# Processed data bucket (matches Dispatcher)
PROCESSED_BUCKET=shorted-processed

# ── Bedrock ───────────────────────────────────────────────────────────────────
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# ── MCP Server ────────────────────────────────────────────────────────────────
# Local development: point to local MCP server
MCP_SERVER_URL=http://localhost:8080
# Production (Lambda Function URL): set after deploy
# MCP_SERVER_URL=https://<function-url-id>.lambda-url.us-east-1.on.aws

MCP_TIMEOUT_SECONDS=30

# ── Pipeline ──────────────────────────────────────────────────────────────────
PIPELINE_VERSION=v1
DEFAULT_LANGUAGE=en
MIN_SNACKS=4
MAX_SNACKS=8
LOCK_TTL_SECONDS=900
MAX_TOOL_LOOPS=20
MAX_REPAIR_ATTEMPTS=1
